{
  "name": "anonymous-reporter",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-Trust Anonymous Reporting System — monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "lint": "npm run lint -w frontend",
    "lint:backend": "npm run lint -w backend",
    "test": "npm run test -w backend",
    "setup:keys": "npm run setup:keys -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
